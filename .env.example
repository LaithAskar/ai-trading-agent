ANTHROPIC_API_KEY=

AGENT_MODEL=claude-sonnet-4-6
AGENT_MAX_ITERS=20
AGENT_MAX_TOKENS_PER_CALL=4096

# Hard kill the loop if the session exceeds these. The dollar cap is computed
# against an approximate pricing table; verify against Anthropic's current prices.
AGENT_MAX_SESSION_TOKENS=200000
AGENT_MAX_SESSION_DOLLARS=1.00

ALPACA_API_KEY=
ALPACA_API_SECRET=
ALPACA_PAPER=true

LIVE_TRADING=false

LOG_LEVEL=INFO

# SEC EDGAR requires a User-Agent identifying the requester (their fair-use policy).
# Format: "Name email@example.com"
SEC_USER_AGENT=trading-agent research you@example.com
